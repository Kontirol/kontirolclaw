{
  "name": "kontirolclaw",
  "version": "1.0.0",
  "description": "AI-powered CLI agent that executes commands through natural language interaction",
  "main": "dist/index.js",
  "bin": {
  "ctrl": "./dist/index.js"
},
  "scripts": {
    "start": "tsx src/index.ts",
    "start:new": "tsx src/index.ts --new-session",
    "start:list": "tsx src/index.ts --list",
    "start:session": "tsx src/index.ts --session",
    "ollama": "node src/ollama.ts",
    "ollama:new": "node src/ollama.ts --new-session",
    "ollama:list": "node src/ollama.ts --list",
    "ollama:session": "node src/ollama.ts --session",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ai",
    "cli",
    "agent",
    "natural-language",
    "automation",
    "command-line"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "axios": "^1.6.0",
    "ollama": "^0.6.3",
    "openai": "^6.32.0",
    "screenshot-desktop": "^1.15.3",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
