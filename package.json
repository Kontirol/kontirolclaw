{
  "name": "ctrl-vscode",
  "displayName": "Ctrl AI - Developer Assistant",
  "version": "1.0.0",
  "description": "DeepSeek-powered AI coding assistant — like Cline, by nijat(Ctrl). Write code, debug, manage files, execute commands, all from your editor.",
  "publisher": "nijat-ctrl",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kontirol/KontirolClaw.git"
  },
  "license": "ISC",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Chat"
  ],
  "keywords": [
    "ai",
    "assistant",
    "coding",
    "deepseek",
    "cline"
  ],
  "activationEvents": [
    "onView:ctrl.chatView"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ctrl-sidebar",
          "title": "Ctrl AI",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "ctrl-sidebar": [
        {
          "type": "webview",
          "id": "ctrl.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "ctrl.openChat",
        "title": "Ctrl: Open Chat",
        "icon": "$(hubot)"
      },
      {
        "command": "ctrl.newSession",
        "title": "Ctrl: New Session"
      },
      {
        "command": "ctrl.clearHistory",
        "title": "Ctrl: Clear History"
      }
    ],
    "configuration": {
      "title": "Ctrl AI",
      "properties": {
        "ctrl.apiKey": {
          "type": "string",
          "default": "",
          "description": "DeepSeek API Key"
        },
        "ctrl.baseURL": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "API Base URL"
        },
        "ctrl.model": {
          "type": "string",
          "default": "deepseek-v4-pro",
          "description": "Model name"
        }
      }
    }
  },
  "dependencies": {
    "openai": "^6.34.0"
  }
}
